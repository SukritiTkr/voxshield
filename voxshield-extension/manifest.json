{
  "manifest_version": 3,
  "name": "VoxShield — Audio-First Browser Defense",
  "version": "1.0.0",
  "description": "Audible, real-time protection against fake CAPTCHA clipboard-hijacking scams and link spoofing, designed for screen reader users.",
  "permissions": ["activeTab", "scripting", "clipboardRead", "storage"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["detectors.js", "voice.js", "content.js"],
      "run_at": "document_idle",
      "all_frames": true
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "VoxShield"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
